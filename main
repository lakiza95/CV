    <script>
        const typedEl = document.getElementById('typedText');
        const phrases = ['Product Manager', 'Product Owner', 'Data-Driven Leader', 'EdTech Expert'];
        let pIdx = 0, cIdx = 0, del = false;
        function type() {
            const cur = phrases[pIdx];
            typedEl.textContent = del ? cur.substring(0, --cIdx) : cur.substring(0, ++cIdx);
            let speed = del ? 40 : 80;
            if (!del && cIdx > cur.length) { speed = 2500; del = true; cIdx = cur.length; }
            else if (del && cIdx < 0) { del = false; pIdx = (pIdx + 1) % phrases.length; speed = 400; }
            setTimeout(type, speed);
        }
        type();

        const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('visible');
                    e.target.querySelectorAll('.skill-bar').forEach(b => setTimeout(() => b.style.width = b.dataset.width, 400));
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.fade-in, .timeline-item').forEach(el => obs.observe(el));

        window.addEventListener('scroll', () => {
            document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 50);
            document.getElementById('backToTop').classList.toggle('visible', window.scrollY > 500);
        });

        function toggleMenu() { document.getElementById('navLinks').classList.toggle('open'); document.getElementById('navToggle').classList.toggle('active'); }
        function closeMenu() { document.getElementById('navLinks').classList.remove('open'); document.getElementById('navToggle').classList.remove('active'); }
        function handleSubmit(e) { e.preventDefault(); showToast('✅ Сообщение отправлено!'); e.target.reset(); }
        function downloadResume(e) { e.preventDefault(); showToast('📄 Скачивание резюме...'); }
        function showToast(msg) { const t = document.getElementById('toast'); t.textContent = msg; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 3000); }
    </script>
</body>
</html>

